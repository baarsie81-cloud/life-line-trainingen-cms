---
interface Props { title: string; text: string; label?: string; href?: string; }
const { title, text, label = "Plan een kennismaking", href = "/contact/" } = Astro.props;
---
<section class="bg-lifeline-blueDark py-16 text-white">
  <div class="container-page grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
    <div class="max-w-3xl"><p class="mb-3 text-sm font-black uppercase tracking-[0.2em] text-lifeline-orange">Samen trainen</p><h2 class="font-display text-3xl font-black sm:text-4xl">{title}</h2><p class="mt-4 text-lg leading-8 text-white/80">{text}</p></div>
    <a href={href} class="focus-ring inline-flex min-h-12 items-center justify-center rounded-md border border-white/70 bg-white px-5 py-3 text-sm font-bold text-lifeline-blueDark hover:bg-lifeline-blueLight">{label}</a>
  </div>
</section>
