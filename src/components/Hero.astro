---
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  image?: string;
  imageAlt?: string;
}

const {
  eyebrow,
  title,
  intro,
  primaryHref = "/contact/",
  primaryLabel = "Neem contact op",
  secondaryHref,
  secondaryLabel,
  image,
  imageAlt = ""
} = Astro.props;
---
<section class="relative overflow-hidden bg-lifeline-sand">
  <div class="container-page relative grid min-h-[520px] items-center gap-10 py-16 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="max-w-3xl">
      <p class="mb-5 text-sm font-black uppercase tracking-[0.22em] text-lifeline-orange">{eyebrow}</p>
      <h1 class="font-display text-4xl font-black leading-tight text-lifeline-blueDark sm:text-5xl lg:text-6xl">{title}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-lifeline-muted">{intro}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={primaryHref} class="focus-ring inline-flex min-h-12 items-center justify-center rounded-md bg-lifeline-orange px-5 py-3 text-sm font-bold text-white shadow-soft hover:bg-lifeline-blueDark">{primaryLabel}</a>
        {secondaryHref && secondaryLabel && <a href={secondaryHref} class="focus-ring inline-flex min-h-12 items-center justify-center rounded-md bg-lifeline-blue px-5 py-3 text-sm font-bold text-white shadow-soft hover:bg-lifeline-blueDark">{secondaryLabel}</a>}
      </div>
    </div>
    <div class="relative hidden min-h-80 lg:block">
      {image ? (
        <div class="absolute inset-0 overflow-hidden rounded-md shadow-soft">
          <img src={image} alt={imageAlt} class="h-full w-full object-cover" loading="eager" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-t from-lifeline-blueDark/70 via-lifeline-blueDark/10 to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8 rounded-md bg-white/95 p-6 shadow-soft">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-lifeline-orange">Sinds 2003</p>
            <p class="mt-3 text-2xl font-black leading-tight text-lifeline-blueDark">Praktijkgerichte training, herkenbaar voor de mensen die moeten handelen.</p>
          </div>
        </div>
      ) : (
        <>
          <div class="absolute inset-0 rounded-md bg-white shadow-soft"></div>
          <img src="/assets/brand/logo-blauw.png" alt="" class="absolute right-8 top-10 w-72" />
          <div class="absolute bottom-8 left-8 right-8 rounded-md bg-lifeline-blueDark p-6 text-white"><p class="text-sm font-bold uppercase tracking-[0.2em] text-lifeline-orange">Sinds 2003</p><p class="mt-3 text-2xl font-black">Trainingen die passen bij de praktijk waarin mensen moeten handelen.</p></div>
        </>
      )}
    </div>
  </div>
</section>
